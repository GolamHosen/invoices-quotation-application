{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/**/pdf/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
