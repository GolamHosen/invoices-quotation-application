# ======================================
# Hujurat Construction - Environment Variables
# ======================================
# Copy this file to .env.local for local development
# Set these variables in Vercel dashboard for deployment

# ----- MongoDB / Database -----
# Required: MongoDB connection string
# For local: mongodb://localhost:27017/hujurat-construction
# For Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
DATABASE_URL=

# Optional: Custom DNS servers for MongoDB SRV lookup (comma-separated)
# Useful if your local/corporate DNS blocks Atlas SRV queries
# Example: 8.8.8.8,8.8.4.4
MONGODB_DNS_SERVERS=

# ----- Authentication -----
# Required: Secret key for signing JWT tokens
# Generate a strong random key: openssl rand -base64 32
JWT_SECRET=

# ----- Cloudinary (Image Uploads) -----
# Required for company logo and file uploads
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- SMTP / Email (Optional - for sending quotations/invoices) -----
# Configure to enable email sending functionality
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ----- Next.js Public URLs (Optional) -----
# Base URL for your application
# In development: http://localhost:3000
# In production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=

# ----- Vercel Deployment Settings -----
# These are automatically set by Vercel, but you can override if needed
# NODE_ENV=production (set automatically by Vercel)
